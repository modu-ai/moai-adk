{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
{{- if eq .Platform "windows"}}
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/moai/handle-session-start.sh\"",
{{- else}}
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/moai/handle-session-start.sh\"",
{{- end}}
            "timeout": 30,
            "type": "command"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "manual|auto",
        "hooks": [
          {
{{- if eq .Platform "windows"}}
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/moai/handle-compact.sh\"",
{{- else}}
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/moai/handle-compact.sh\"",
{{- end}}
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
{{- if eq .Platform "windows"}}
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/moai/handle-session-end.sh\"",
{{- else}}
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/moai/handle-session-end.sh\"",
{{- end}}
            "timeout": 10,
            "type": "command"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
{{- if eq .Platform "windows"}}
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/moai/handle-pre-tool.sh\"",
{{- else}}
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/moai/handle-pre-tool.sh\"",
{{- end}}
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "Write|Edit|Bash"
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
{{- if eq .Platform "windows"}}
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/moai/handle-post-tool.sh\"",
{{- else}}
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/moai/handle-post-tool.sh\"",
{{- end}}
            "timeout": 60,
            "type": "command"
          }
        ],
        "matcher": "Write|Edit"
      },
      {
        "hooks": [
          {
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/moai/handle-db-schema-change.sh\"",
            "timeout": 30,
            "type": "command"
          }
        ],
        "matcher": "Write|Edit"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
{{- if eq .Platform "windows"}}
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/moai/handle-stop.sh\"",
{{- else}}
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/moai/handle-stop.sh\"",
{{- end}}
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
{{- if eq .Platform "windows"}}
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/moai/handle-subagent-stop.sh\"",
{{- else}}
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/moai/handle-subagent-stop.sh\"",
{{- end}}
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
{{- if eq .Platform "windows"}}
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/moai/handle-post-tool-failure.sh\"",
{{- else}}
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/moai/handle-post-tool-failure.sh\"",
{{- end}}
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
{{- if eq .Platform "windows"}}
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/moai/handle-notification.sh\"",
{{- else}}
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/moai/handle-notification.sh\"",
{{- end}}
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
{{- if eq .Platform "windows"}}
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/moai/handle-subagent-start.sh\"",
{{- else}}
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/moai/handle-subagent-start.sh\"",
{{- end}}
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
{{- if eq .Platform "windows"}}
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/moai/handle-user-prompt-submit.sh\"",
{{- else}}
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/moai/handle-user-prompt-submit.sh\"",
{{- end}}
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [
          {
{{- if eq .Platform "windows"}}
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/moai/handle-teammate-idle.sh\"",
{{- else}}
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/moai/handle-teammate-idle.sh\"",
{{- end}}
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
{{- if eq .Platform "windows"}}
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/moai/handle-task-completed.sh\"",
{{- else}}
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/moai/handle-task-completed.sh\"",
{{- end}}
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "hooks": [
          {
{{- if eq .Platform "windows"}}
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/moai/handle-worktree-create.sh\"",
{{- else}}
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/moai/handle-worktree-create.sh\"",
{{- end}}
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "hooks": [
          {
{{- if eq .Platform "windows"}}
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/moai/handle-worktree-remove.sh\"",
{{- else}}
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/moai/handle-worktree-remove.sh\"",
{{- end}}
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "TaskCreated": [
      {
        "hooks": [
          {
{{- if eq .Platform "windows"}}
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/moai/handle-task-created.sh\"",
{{- else}}
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/moai/handle-task-created.sh\"",
{{- end}}
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "ConfigChange": [
      {
        "matcher": "project_settings|local_settings|skills",
        "hooks": [
          {
{{- if eq .Platform "windows"}}
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/moai/handle-config-change.sh\"",
{{- else}}
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/moai/handle-config-change.sh\"",
{{- end}}
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "matcher": "rate_limit|authentication_failed|billing_error|max_output_tokens",
        "hooks": [
          {
{{- if eq .Platform "windows"}}
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/moai/handle-stop-failure.sh\"",
{{- else}}
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/moai/handle-stop-failure.sh\"",
{{- end}}
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "manual|auto",
        "hooks": [
          {
{{- if eq .Platform "windows"}}
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/moai/handle-post-compact.sh\"",
{{- else}}
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/moai/handle-post-compact.sh\"",
{{- end}}
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "InstructionsLoaded": [
      {
        "hooks": [
          {
{{- if eq .Platform "windows"}}
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/moai/handle-instructions-loaded.sh\"",
{{- else}}
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/moai/handle-instructions-loaded.sh\"",
{{- end}}
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "CwdChanged": [
      {
        "hooks": [
          {
{{- if eq .Platform "windows"}}
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/moai/handle-cwd-changed.sh\"",
{{- else}}
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/moai/handle-cwd-changed.sh\"",
{{- end}}
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "FileChanged": [
      {
        "hooks": [
          {
{{- if eq .Platform "windows"}}
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/moai/handle-file-changed.sh\"",
{{- else}}
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/moai/handle-file-changed.sh\"",
{{- end}}
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": ".env|.envrc|.gitignore"
      }
    ],
    "Elicitation": [
      {
        "hooks": [
          {
{{- if eq .Platform "windows"}}
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/moai/handle-elicitation.sh\"",
{{- else}}
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/moai/handle-elicitation.sh\"",
{{- end}}
            "timeout": 10,
            "type": "command"
          }
        ]
      }
    ],
    "ElicitationResult": [
      {
        "hooks": [
          {
{{- if eq .Platform "windows"}}
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/moai/handle-elicitation-result.sh\"",
{{- else}}
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/moai/handle-elicitation-result.sh\"",
{{- end}}
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "PermissionDenied": [
      {
        "hooks": [
          {
{{- if eq .Platform "windows"}}
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/moai/handle-permission-denied.sh\"",
{{- else}}
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/moai/handle-permission-denied.sh\"",
{{- end}}
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
{{- if eq .Platform "windows"}}
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/moai/handle-permission-request.sh\"",
{{- else}}
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/moai/handle-permission-request.sh\"",
{{- end}}
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": ".moai/status_line.sh",
    "refreshInterval": 10
  },
  "outputStyle": "MoAI",
  "showThinkingSummaries": false,
  "cleanupPeriodDays": 30,
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_FILE_READ_MAX_OUTPUT_TOKENS": "64000",
    "ENABLE_TOOL_SEARCH": "1",
    "MOAI_CONFIG_SOURCE": "sections",
    "CLAUDE_CODE_NO_FLICKER": "1",
    "CLAUDE_CODE_SUBPROCESS_ENV_SCRUB": "1",
    "PATH": "{{jsonEscape .SmartPATH}}"
  },
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "AskUserQuestion",
      "BashOutput",
      "Edit",
      "Glob",
      "Grep",
      "KillShell",
      "MultiEdit",
      "NotebookEdit",
      "Read",
      "Skill",
      "Agent",
      "TaskCreate",
      "TaskGet",
      "TaskList",
      "TaskUpdate",
      "TodoWrite",
      "WebFetch",
      "WebSearch",
      "Write",
      "CronCreate",
      "CronList",
      "CronDelete",
      "EnterWorktree",
      "ExitWorktree",
      "EnterPlanMode",
      "ExitPlanMode",
      "ListMcpResourcesTool",
      "ReadMcpResourceTool",
      "mcp__context7__get-library-docs",
      "mcp__context7__resolve-library-id",
      "mcp__sequential-thinking__*",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git blame:*)",
      "Bash(git branch:*)",
      "Bash(git remote:*)",
      "Bash(git config:*)",
      "Bash(git tag:*)",
      "Bash(git add:*)",
