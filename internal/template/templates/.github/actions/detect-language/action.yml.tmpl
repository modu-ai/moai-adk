name: 'Detect Programming Language'
description: 'Detects the primary programming language from repository files'
outputs:
  language:
    description: 'Detected language (go, python, typescript, javascript, rust, java, kotlin, csharp, ruby, php, elixir, cpp, scala, r, flutter, swift)'
    value: ${{ "{{" }} steps.detect.outputs.language }}}

runs:
  using: 'composite'
  steps:
    - id: detect
      shell: bash
      run: |
        LANG_COUNT=$(find . -name "*.go" -o -name "*.py" -o -name "*.ts" -o -name "*.js" | \
          grep -v node_modules | grep -v vendor | grep -v ".git" | \
          head -1 | sed 's/.*\.//' | sort | uniq -c | sort -rn | head -1 | \
          awk '{print $2}')

        case "$LANG_COUNT" in
          go) echo "language=go" >> $GITHUB_OUTPUT ;;
          py) echo "language=python" >> $GITHUB_OUTPUT ;;
          ts) echo "language=typescript" >> $GITHUB_OUTPUT ;;
          js) echo "language=javascript" >> $GITHUB_OUTPUT ;;
          rs) echo "language=rust" >> $GITHUB_OUTPUT ;;
          java) echo "language=java" >> $GITHUB_OUTPUT ;;
          kt) echo "language=kotlin" >> $GITHUB_OUTPUT ;;
          cs) echo "language=csharp" >> $GITHUB_OUTPUT ;;
          rb) echo "language=ruby" >> $GITHUB_OUTPUT ;;
          php) echo "language=php" >> $GITHUB_OUTPUT ;;
          ex) echo "language=elixir" >> $GITHUB_OUTPUT ;;
          cpp) echo "language=cpp" >> $GITHUB_OUTPUT ;;
          scala) echo "language=scala" >> $GITHUB_OUTPUT ;;
          r) echo "language=r" >> $GITHUB_OUTPUT ;;
          flutter) echo "language=flutter" >> $GITHUB_OUTPUT ;;
          swift) echo "language=swift" >> $GITHUB_OUTPUT ;;
          *) echo "language=unknown" >> $GITHUB_OUTPUT ;;
        esac
