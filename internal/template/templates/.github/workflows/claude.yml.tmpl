name: Claude Code Review (Issue Trigger)

on:
  issues:
    types: [opened, edited]
  issue_comment:
    types: [created]

permissions:
  contents: read
  issues: write

concurrency:
  group: claude-issue-${{ github.event.issue.number }}
  cancel-in-progress: true

jobs:
  claude-review:
    name: Claude Review
    # REQ-SEC-010: External contributor guard
    if: |
      github.event.author_association == 'OWNER' ||
      github.event.author_association == 'MEMBER' ||
      github.event.author_association == 'COLLABORATOR'
    runs-on: ${{ fromJson(format('["self-hosted", "{0}", "{1}", "{2}"]', runner.os, runner.arch, runner.project)) }}
    env:
      CLAUDE_CODE_OAUTH_TOKEN: ${{ secrets.CLAUDE_CODE_OAUTH_TOKEN }}

    steps:
      - name: Cleanup workspace
        if: always()
        # REQ-SEC-005: Workspace cleanup (remove .env files, preserve auth.json)
        run: |
          find "$GITHUB_WORKSPACE" -name "*.env" -delete 2>/dev/null || true

      - name: Checkout repository
        uses: actions/checkout@08c6903cd8c0fde910a37f88322edcfb5dd907a8 # v5.8.0
        with:
          clean: true # REQ-SEC-005.1: Preserve default clean behavior

      - name: Detect project language
        id: detect-language
        uses: ./.github/actions/detect-language
        # REQ-CI-012: 16-language neutrality via composite action

      - name: Setup project environment
        if: steps.detect-language.outputs.languages != '[]'
        run: |
          echo "Detected languages: ${{ steps.detect-language.outputs.languages }}"
          # Dynamic build/test setup based on detected languages
          # This step would be extended in full implementation

      - name: Run Claude Code Review
        # REQ-CI-014: Comment trigger with prompt argument support
        # REQ-CI-018: SHA-pin enforcement (avoid v1.0.79-84)
        # REQ-CI-018.3: Action SHA injected via config (workflows.claude.action_sha)
        uses: anthropics/claude-code-action@${{ github.event.repository.actions.workflows.claude.action_sha || '85c9e3e10a8868d3ebbffd75e1ffd3e8f7e45d17' }} # v1.0.85+
        with:
          prompt: |
            You are Claude Code, an AI programming assistant reviewing this GitHub issue.

            Issue: ${{ github.event.issue.title }}
            URL: ${{ github.event.issue.html_url }}
            Body: ${{ github.event.issue.body }}

            ${{ github.event_name == 'issue_comment' && format('Comment: {0}', github.event.comment.body) || '' }}

            Please analyze this issue and provide:
            1. Understanding of the problem/request
            2. Suggested approach or solution
            3. Potential edge cases to consider
            4. Code examples if applicable

            Keep responses concise and actionable.
        env:
          ANTHROPIC_API_KEY: ${{ secrets.CLAUDE_CODE_OAUTH_TOKEN }}

      - name: Handle authentication errors
        if: failure()
        # REQ-SEC-009: Token expiration detection (401 response handling)
        run: |
          echo "AUTH_EXPIRED: The CLAUDE_CODE_OAUTH_TOKEN has expired or is invalid."
          echo "Please rotate the secret by running: moai github auth claude"
          echo ""
          echo "See: https://docs.anthropic.com/en/api/client-sdks"
          exit 1

      - name: Post review as comment
        if: success() || failure()
        uses: actions/github-script@60a0d83039c74a4aee543508d2ffcb1c3799c6a7 # v7.0.1
        with:
          github-token: ${{ secrets.GITHUB_TOKEN }}
          script: |
            const issueNumber = context.issue.number;
            const commentBody = `### 🤖 Claude Code Review

            ${{ steps.run-claude-code-review.outputs.review || 'Review completed. Check the job logs for details.' }}`;

            github.rest.issues.createComment({
              issue_number: issueNumber,
              owner: context.repo.owner,
              repo: context.repo.repo,
              body: commentBody
            });
