<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>MoAI Web Console</title>
  <link rel="stylesheet" href="/static/console.css">
  <script>
    // FOUC-prevention: apply the persisted theme + interface language before
    // first paint (REQ-WC4-006 / REQ-WC5-005). Client-side only — no server
    // round-trip, no theme/language persistence field. Setting <html lang>
    // early activates the CJK @font-face stack for ja/zh before paint so the
    // first render already uses the brand webfont (no system-ui flash).
    (function () {
      try {
        var t = localStorage.getItem("moai-console-theme");
        if (t === "dark" || t === "light") {
          document.documentElement.setAttribute("data-theme", t);
        }
      } catch (e) { /* localStorage unavailable — keep the default light theme */ }
      try {
        var l = localStorage.getItem("moai-console-lang");
        if (l === "en" || l === "ko" || l === "ja" || l === "zh") {
          document.documentElement.setAttribute("lang", l);
        }
      } catch (e) { /* localStorage unavailable — keep the default en interface */ }
    })();
  </script>
</head>
<body>

  <!-- ============ App bar (brand strip) — REQ-WC4-004 ============ -->
  <header class="appbar">
    <span class="brand" aria-label="모두의AI — MoAI">
      <span class="brand__badge">
        <svg width="21" height="27" viewBox="0 0 40 50" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M8 40 L32 40 L34 50 L6 50 Z" fill="#fff"/>
          <path d="M12 4 L28 4 L31 16 L30.5 34 L25 42 L15 42 L9.5 34 L9 16 Z" fill="#fff"/>
          <path d="M9 16 L31 16 L30.6 21 L9.4 21 Z" fill="#0c3a37"/>
          <path d="M12.5 22 L18 22 L17.4 27 L13.1 27 Z" fill="#0a2825"/>
          <path d="M22 22 L27.5 22 L26.9 27 L22.6 27 Z" fill="#0a2825"/>
          <path d="M18.7 20.5 L21.3 20.5 L23 33 L17 33 Z" fill="#1d6b62"/>
          <path d="M15.5 35 L24.5 35 L24 38.5 L16 38.5 Z" fill="#0a2825"/>
        </svg>
      </span>
      <span class="brand__name">모두의AI</span>
    </span>
    <span class="appbar__divider"></span>
    <span class="loopback"><span class="loopback__dot"></span>{{.BindAddr}}</span>
    <span class="appbar__spacer"></span>
    <!-- Interface-language picker (REQ-WC5-003) — a NON-form widget: it lives in
         the appbar (which precedes the settings form), carries NO name= attribute,
         submits nothing, and persists ONLY in localStorage("moai-console-lang").
         It switches the UI chrome language (data-i18n), NOT the server-validated
         content-language settings. id="uiLangSelect" deliberately avoids the
         "langSelect" content-language helper id to keep interface and content
         language orthogonal (the cohort core invariant). -->
    <span class="select-wrap langpick-wrap">
      <select class="select langpick" id="uiLangSelect" aria-label="Interface language" title="Interface language">
        <option value="en">English</option>
        <option value="ko">한국어</option>
        <option value="ja">日本語</option>
        <option value="zh">中文</option>
      </select>
    </span>
    <button class="iconbtn" id="themeToggle" type="button" aria-label="Toggle light / dark theme" title="Toggle theme">
      {{template "icon" "sun"}}
      {{template "icon" "moon"}}
    </button>
  </header>

  <main class="page">

    <!-- ============ Page header ============ -->
    <div class="pagehead">
      <h1>MoAI <span class="accent">Web Console</span></h1>
      <p class="pagehead__sub" data-i18n="app.subtitle">Edit profile preferences &amp; project settings (loopback only — local machine)</p>
    </div>

    <!-- ============ Profile switcher (server-conditional) ============ -->
    {{if .ShowProfileSwitch}}
    <div class="profilebar">
      <label class="profilebar__label" for="__profile_select" data-i18n="profile.label">Profile:</label>
      <span class="select-wrap">
        <select class="select" name="__profile_select" id="__profile_select" aria-label="Active profile">
          {{range .Profiles}}
          <option value="{{.Name}}" {{if eq .Name $.SelectedProfile}}selected{{end}}>{{.Name}}{{if .Current}} (current){{end}}</option>
          {{end}}
        </select>
      </span>
      <span class="profilebar__meta">selected: <strong>{{.SelectedProfile}}</strong></span>
    </div>
    {{end}}

    <!-- ============ Save banner (server-rendered; kind ok/error → success/error) ============ -->
    {{if .Banner}}
    <div class="banner {{if eq .BannerKind "error"}}banner--error{{else}}banner--success{{end}}" role="status" aria-live="polite">
      <span class="banner__icon">{{if eq .BannerKind "error"}}{{template "icon" "alert-circle"}}{{else}}{{template "icon" "check-circle"}}{{end}}</span>
      <div class="banner__body">
        <p class="banner__text">{{.Banner}}</p>
      </div>
    </div>
    {{end}}

    <!-- ============ Form ============ -->
    <form class="form" method="POST" action="/save{{if .SelectedProfile}}?profile={{.SelectedProfile}}{{end}}">
      <input type="hidden" name="__profile" value="{{.SelectedProfile}}">

      <!-- ---- 1. Identity ---- -->
      <fieldset class="section">
        <div class="section__head">
          <div class="section__head-row">
            <legend class="section__legend"><span class="section__ico">{{template "icon" "user-round"}}</span><span data-i18n="sec.identity.title">Identity</span></legend>
            <span class="section__count" data-i18n="count.identity">1 field</span>
          </div>
          <p class="section__desc" data-i18n="sec.identity.desc">Who you are in commits and sessions.</p>
        </div>
        <div class="section__body">
          <div class="grid grid--1">
            <div class="field {{if index .FieldErrors "user_name"}}has-error{{end}}">
              <span class="field__label"><span class="field__title" data-i18n="f.user_name.title">Display name</span><code class="field__key">user_name</code></span>
              <span class="field__desc" data-i18n="f.user_name.desc">The name shown in commits and session headers.</span>
              <input class="input" type="text" id="user_name" name="user_name" value="{{.Prefs.UserName}}" placeholder="e.g. jline" autocomplete="off"{{if index .FieldErrors "user_name"}} aria-invalid="true" aria-describedby="err_user_name"{{end}}>
              {{with index .FieldErrors "user_name"}}<span class="field-error" id="err_user_name">{{template "icon" "alert-circle"}}<span>{{.}}</span></span>{{end}}
            </div>
          </div>
        </div>
      </fieldset>

      <!-- ---- 2. Language ---- -->
      <fieldset class="section">
        <div class="section__head">
          <div class="section__head-row">
            <legend class="section__legend"><span class="section__ico">{{template "icon" "languages"}}</span><span data-i18n="sec.language.title">Language</span></legend>
            <span class="section__count" data-i18n="count.language">4 fields</span>
          </div>
          <p class="section__desc" data-i18n="sec.language.desc">Languages used across conversation, commits, comments, and docs.</p>
        </div>
        <div class="section__body">
          <div class="grid">
            {{template "langSelect" dict "Name" "conversation_lang" "Title" "Conversation language" "Key" "conversation_lang" "Desc" "Language the assistant replies in during chat." "Value" .Prefs.ConversationLang "Errors" .FieldErrors "Options" .LangOptions}}
            {{template "langSelect" dict "Name" "git_commit_lang" "Title" "Commit message language" "Key" "git_commit_lang" "Desc" "Language used when writing git commit messages." "Value" .Prefs.GitCommitLang "Errors" .FieldErrors "Options" .LangOptions}}
            {{template "langSelect" dict "Name" "code_comment_lang" "Title" "Code comment language" "Key" "code_comment_lang" "Desc" "Language for comments written into your code." "Value" .Prefs.CodeCommentLang "Errors" .FieldErrors "Options" .LangOptions}}
            {{template "langSelect" dict "Name" "doc_lang" "Title" "Documentation language" "Key" "doc_lang" "Desc" "Language for generated docs and READMEs." "Value" .Prefs.DocLang "Errors" .FieldErrors "Options" .LangOptions}}
          </div>
        </div>
      </fieldset>

      <!-- ---- 3. Launch ---- -->
      <fieldset class="section">
        <div class="section__head">
          <div class="section__head-row">
            <legend class="section__legend"><span class="section__ico">{{template "icon" "rocket"}}</span><span data-i18n="sec.launch.title">Launch</span></legend>
            <span class="section__count" data-i18n="count.launch">4 fields</span>
          </div>
          <p class="section__desc" data-i18n="sec.launch.desc">How sessions start — permissions, model, and reasoning effort.</p>
        </div>
        <div class="section__body">
          <div class="grid">
            <div class="field {{if index .FieldErrors "permission_mode"}}has-error{{end}}">
              <span class="field__label"><span class="field__title" data-i18n="f.permission_mode.title">Permission mode</span><code class="field__key">permission_mode</code></span>
              <span class="field__desc" data-i18n="f.permission_mode.desc">How much the agent may do before asking you.</span>
              <span class="select-wrap">
                <select class="select" id="permission_mode" name="permission_mode"{{if index .FieldErrors "permission_mode"}} aria-invalid="true" aria-describedby="err_permission_mode"{{end}}>
                  {{range .PermissionModes}}
                  <option value="{{.}}" {{if eq . $.Prefs.PermissionMode}}selected{{end}}>{{if eq . ""}}(project default){{else}}{{.}}{{end}}</option>
                  {{end}}
                </select>
              </span>
              {{with index .FieldErrors "permission_mode"}}<span class="field-error" id="err_permission_mode">{{template "icon" "alert-circle"}}<span>{{.}}</span></span>{{end}}
            </div>
            {{template "optSelect" dict "Name" "model_policy" "Title" "Model policy" "Key" "model_policy" "Desc" "Quality vs. speed bias when a model is auto-selected." "Value" .Prefs.ModelPolicy "Empty" "(unset)" "Errors" .FieldErrors "Options" .ModelPolicies}}
            {{template "optSelect" dict "Name" "model" "Title" "Model" "Key" "model" "Desc" "The specific model to run, including 1M-context variants." "Value" .Prefs.Model "Empty" "(project default)" "Errors" .FieldErrors "Options" .ModelOptions}}
            {{template "optSelect" dict "Name" "effort_level" "Title" "Effort level" "Key" "effort_level" "Desc" "How much reasoning effort the model spends per task." "Value" .Prefs.EffortLevel "Empty" "(runtime default)" "Errors" .FieldErrors "Options" .EffortLevels}}
          </div>
        </div>
      </fieldset>

      <!-- ---- 4. Statusline ---- -->
      <fieldset class="section">
        <div class="section__head">
          <div class="section__head-row">
            <legend class="section__legend"><span class="section__ico">{{template "icon" "panel-bottom"}}</span><span data-i18n="sec.statusline.title">Statusline</span></legend>
            <span class="section__count" data-i18n="count.statusline">3 fields · segments</span>
          </div>
          <p class="section__desc" data-i18n="sec.statusline.desc">The status bar shown at the bottom of your terminal.</p>
        </div>
        <div class="section__body">
          <div class="grid">
            <div class="field {{if index .FieldErrors "statusline_mode"}}has-error{{end}}">
              <span class="field__label"><span class="field__title" data-i18n="f.statusline_mode.title">Statusline mode</span><code class="field__key">statusline_mode</code></span>
              <span class="field__desc" data-i18n="f.statusline_mode.desc">Overall density of the status bar.</span>
              <span class="select-wrap">
                <select class="select" id="statusline_mode" name="statusline_mode"{{if index .FieldErrors "statusline_mode"}} aria-invalid="true" aria-describedby="err_statusline_mode"{{end}}>
                  {{range .StatuslineModes}}
                  <option value="{{.}}" {{if eq . $.Prefs.StatuslineMode}}selected{{end}}>{{.}}</option>
                  {{end}}
                </select>
              </span>
              {{with index .FieldErrors "statusline_mode"}}<span class="field-error" id="err_statusline_mode">{{template "icon" "alert-circle"}}<span>{{.}}</span></span>{{end}}
            </div>
            <div class="field {{if index .FieldErrors "statusline_preset"}}has-error{{end}}">
              <span class="field__label"><span class="field__title" data-i18n="f.statusline_preset.title">Statusline preset</span><code class="field__key">statusline_preset</code></span>
              <span class="field__desc" data-i18n="f.statusline_preset.desc">A predefined segment set. Choose “custom” to pick your own.</span>
              <span class="select-wrap">
                <select class="select" id="statusline_preset" name="statusline_preset"{{if index .FieldErrors "statusline_preset"}} aria-invalid="true" aria-describedby="err_statusline_preset"{{end}}>
                  {{range .StatuslinePresets}}
                  <option value="{{.}}" {{if eq . $.Prefs.StatuslinePreset}}selected{{end}}>{{.}}</option>
                  {{end}}
                </select>
              </span>
              {{with index .FieldErrors "statusline_preset"}}<span class="field-error" id="err_statusline_preset">{{template "icon" "alert-circle"}}<span>{{.}}</span></span>{{end}}
            </div>
            <div class="field col-span-2 {{if index .FieldErrors "statusline_theme"}}has-error{{end}}">
              <span class="field__label"><span class="field__title" data-i18n="f.statusline_theme.title">Statusline theme</span><code class="field__key">statusline_theme</code></span>
              <span class="field__desc" data-i18n="f.statusline_theme.desc">Color theme for the status bar.</span>
              <span class="select-wrap" style="max-width:340px">
                <select class="select" id="statusline_theme" name="statusline_theme"{{if index .FieldErrors "statusline_theme"}} aria-invalid="true" aria-describedby="err_statusline_theme"{{end}}>
                  {{range .StatuslineThemes}}
                  <option value="{{.}}" {{if eq . $.Prefs.StatuslineTheme}}selected{{end}}>{{.}}</option>
                  {{end}}
                </select>
              </span>
              {{with index .FieldErrors "statusline_theme"}}<span class="field-error" id="err_statusline_theme">{{template "icon" "alert-circle"}}<span>{{.}}</span></span>{{end}}
            </div>
          </div>

          <!-- Custom segments (visibility toggled client-side when preset==custom).
               The checkboxes are always present in markup so they round-trip;
               bindForm binds segment_<key> only when preset==custom (EC-5). -->
          <div class="segments" id="custom-segments">
            <div class="segments__head">
              <span class="segments__title" data-i18n="seg.title">Custom segments</span>
              <span class="segments__note" data-i18n="seg.note">Choose exactly which pieces of information appear.</span>
            </div>
            <div class="segments__grid">
              {{range .AllSegments}}
              <label class="seg"><input type="checkbox" name="segment_{{.}}" value="1" {{if index $.Prefs.StatuslineSegments .}}checked{{end}}><span class="seg__box"><span class="seg__tick">{{template "icon" "check"}}</span><span class="seg__name">{{.}}</span></span></label>
              {{end}}
            </div>
          </div>
        </div>
      </fieldset>

      <!-- ---- 5. Project ---- -->
      <fieldset class="section">
        <div class="section__head">
          <div class="section__head-row">
            <legend class="section__legend"><span class="section__ico">{{template "icon" "folder-git"}}</span><span data-i18n="sec.project.title">Project</span></legend>
            <span class="section__count" data-i18n="count.project">2 fields</span>
          </div>
          <p class="section__desc" data-i18n="sec.project.desc">Project-level development and git conventions.</p>
        </div>
        <div class="section__body">
          <div class="grid">
            {{template "optSelect" dict "Name" "development_mode" "Title" "Development mode" "Key" "development_mode" "Desc" "Default workflow — domain-driven (DDD) or test-driven (TDD)." "Value" .CurDevelopmentMode "Empty" "(project default)" "Errors" .FieldErrors "Options" .DevelopmentModes}}
            {{template "optSelect" dict "Name" "git_convention" "Title" "Git convention" "Key" "git_convention" "Desc" "Commit message convention enforced in this project." "Value" .CurConvention "Empty" "(project default)" "Errors" .FieldErrors "Options" .Conventions}}
          </div>
        </div>
      </fieldset>

      <!-- ---- Actions ---- -->
      <div class="actions">
        <button class="btn btn--primary" type="submit">{{template "icon" "save"}}<span data-i18n="actions.save">Save settings</span></button>
        <span class="actions__meta" data-i18n="actions.meta">writes to ~/.moai profile &amp; project config</span>
      </div>
    </form>
  </main>
  <script src="/static/i18n.js"></script>
  <script src="/static/app.js"></script>
</body>
</html>

{{define "langSelect"}}
<div class="field {{if index .Errors .Name}}has-error{{end}}">
  <span class="field__label"><span class="field__title" data-i18n="f.{{.Name}}.title">{{.Title}}</span><code class="field__key">{{.Key}}</code></span>
  <span class="field__desc" data-i18n="f.{{.Name}}.desc">{{.Desc}}</span>
  <span class="select-wrap">
    <select class="select select--lang" id="{{.Name}}" name="{{.Name}}"{{if index .Errors .Name}} aria-invalid="true"{{end}}>
      <option value="" {{if eq .Value ""}}selected{{end}}>(unset)</option>
      {{range .Options}}
      <option value="{{.}}" {{if eq . $.Value}}selected{{end}}>{{.}}</option>
      {{end}}
    </select>
  </span>
  {{with index .Errors .Name}}<span class="field-error">{{template "icon" "alert-circle"}}<span>{{.}}</span></span>{{end}}
</div>
{{end}}

{{define "optSelect"}}
<div class="field {{if index .Errors .Name}}has-error{{end}}">
  <span class="field__label"><span class="field__title" data-i18n="f.{{.Name}}.title">{{.Title}}</span><code class="field__key">{{.Key}}</code></span>
  <span class="field__desc" data-i18n="f.{{.Name}}.desc">{{.Desc}}</span>
  <span class="select-wrap">
    <select class="select" id="{{.Name}}" name="{{.Name}}"{{if index .Errors .Name}} aria-invalid="true"{{end}}>
      <option value="" {{if eq .Value ""}}selected{{end}}>{{.Empty}}</option>
      {{range .Options}}
      <option value="{{.}}" {{if eq . $.Value}}selected{{end}}>{{.}}</option>
      {{end}}
    </select>
  </span>
  {{with index .Errors .Name}}<span class="field-error">{{template "icon" "alert-circle"}}<span>{{.}}</span></span>{{end}}
</div>
{{end}}

{{/*
  Inline-SVG icon subset (REQ-WC4-007) — no lucide CDN <script>, no runtime
  icon-library JS. Each icon is a small inline <svg> selected by name. The
  lucide icon set is ISC-licensed; these paths are derived from lucide.
*/}}
{{define "icon"}}
{{- if eq . "user-round" -}}
<svg class="icon-user-round" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="8" r="5"/><path d="M20 21a8 8 0 0 0-16 0"/></svg>
{{- else if eq . "languages" -}}
<svg class="icon-languages" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m5 8 6 6"/><path d="m4 14 6-6 2-3"/><path d="M2 5h12"/><path d="M7 2h1"/><path d="m22 22-5-10-5 10"/><path d="M14 18h6"/></svg>
{{- else if eq . "rocket" -}}
<svg class="icon-rocket" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/></svg>
{{- else if eq . "panel-bottom" -}}
<svg class="icon-panel-bottom" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M3 15h18"/></svg>
{{- else if eq . "folder-git" -}}
<svg class="icon-folder-git" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="13" r="2"/><path d="M14.05 22H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h3.9a2 2 0 0 1 1.69.9l.81 1.2a2 2 0 0 0 1.67.9H20a2 2 0 0 1 2 2v3.5"/><path d="M14 13h3"/><path d="M7 13h3"/></svg>
{{- else if eq . "sun" -}}
<svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>
{{- else if eq . "moon" -}}
<svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
{{- else if eq . "save" -}}
<svg class="icon-save" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15.2 3a2 2 0 0 1 1.4.6l3.8 3.8a2 2 0 0 1 .6 1.4V19a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2z"/><path d="M17 21v-7a1 1 0 0 0-1-1H8a1 1 0 0 0-1 1v7"/><path d="M7 3v4a1 1 0 0 0 1 1h7"/></svg>
{{- else if eq . "check" -}}
<svg class="icon-check" xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
{{- else if eq . "check-circle" -}}
<svg class="icon-check-circle" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21.801 10A10 10 0 1 1 17 3.335"/><path d="m9 11 3 3L22 4"/></svg>
{{- else if eq . "alert-circle" -}}
<svg class="icon-alert-circle" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" x2="12" y1="8" y2="12"/><line x1="12" x2="12.01" y1="16" y2="16"/></svg>
{{- else if eq . "chevron-down" -}}
<svg class="icon-chevron-down" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
